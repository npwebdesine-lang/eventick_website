{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production"
  },
  "regions": ["iad1"],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/modules",
      "destination": "/modules.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    }
  ]
}
